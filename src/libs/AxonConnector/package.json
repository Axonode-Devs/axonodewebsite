  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/example/axonconnector.git"
  },
  "homepage": "https://github.com/example/axonconnector#readme",
  "bugs": {
    "url": "https://github.com/example/axonconnector/issues"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "axios": "^1.13.5"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "prettier": "^3.0.0"
  }
}

