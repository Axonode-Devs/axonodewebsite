{
  "name": "axonconnector",
  "version": "1.0.0",
  "description": "A lightweight, Firebase-like convenience library for seamless integration with the Axonode Backend API. Handles user authentication, account management, and admin operations with automatic JWT token management.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\""
  },
  "keywords": [
    "axonode",
    "authentication",
    "jwt",
    "api-client",
    "http",
    "axios",
    "user-management",
    "admin-panel"
  ],
