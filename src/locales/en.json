    "vision": {
      "title": "Vision",
      "description": "To redefine the architecture of multi-participant projects and professional networking. We envision a future where the weight of \"finding the right team\" is put away. Our goal is to create a high-efficiency environment with collective power of a hyper-connected community."
    },
    "mission": {
      "title": "Mission",
      "description": "To enhance professional growth by simplifying the way people connect. At Axonode, we connect the subjects of career and giving the people a network they don't have to worry about, making business networking intuitive and accessible. By creating a global ecosystem for voluntary project participation, we give every developer, designer, and entrepreneur a platform to contribute their skills and build their portfolio."
    }
